---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Content Management</title>
  </head>
  <body>
    <script>
      // @ts-expect-error — @sveltia/cms does not ship types compatible with all tsconfigs
      import { init } from "@sveltia/cms";
      // @ts-expect-error — virtual module resolved at runtime by the Vite plugin
      import { config, title } from "virtual:astro-sveltia-cms/config";

      if (title !== undefined) {
        document.title = title;
      }
      init({ config });
    </script>
  </body>
</html>
