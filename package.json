{
  "name": "astro-loader-sveltia-cms",
  "version": "0.1.2",
  "description": "Sveltia CMS integration for Astro",
  "keywords": [
    "astro-integration",
    "astro-loader",
    "sveltiacms",
    "withastro"
  ],
  "homepage": "https://github.com/joknoll/astro-loader-sveltia-cms#readme",
  "bugs": {
    "url": "https://github.com/joknoll/astro-loader-sveltia-cms/issues"
  },
  "license": "ISC",
  "author": "Johannes Knoll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joknoll/astro-loader-sveltia-cms.git"
  },
  "directories": {
    "example": "example"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    },
    "./admin.astro": "./dist/admin.astro"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && cp src/admin.astro dist/admin.astro",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sveltia/cms": "^0.146.2",
    "zod-to-ts": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "astro": "^6.0.2",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "astro": "^6.0.2"
  }
}
